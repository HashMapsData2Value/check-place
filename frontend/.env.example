### Frontend environment example
# Set this to your backend origin (include protocol and port when running locally)
# Leave empty to use same-origin (e.g., when frontend and backend are served together)
VITE_API_BASE_URL=http://localhost:3001
# Optional: public Maps SDK key used only for client-side map rendering. Restrict key via Google console.
VITE_GOOGLE_MAPS_API_KEY=your_public_maps_js_key_here